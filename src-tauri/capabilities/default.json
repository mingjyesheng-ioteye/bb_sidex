{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "SideX IDE permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
 
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",

    "shell:default",
    "shell:allow-open",

    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
