        "node": { "files": 50, "strategy": "rewrite-rust", "status": "planned" },
        "parts/ipc": { "files": 15, "strategy": "rewrite-tauri", "status": "planned" },
        "parts/storage": { "files": 5, "strategy": "rewrite-rust", "status": "planned" }
      }
    },
    "platform": {
      "description": "93 platform services via dependency injection",
      "vscode_files": 800,
      "service_count": 93,
      "critical_services": [
        "instantiation", "files", "windows", "configuration", "storage",
        "keybinding", "commands", "contextkey", "theme", "log",
        "terminal", "dialogs", "clipboard", "native", "encryption",
        "lifecycle", "environment", "product", "request", "telemetry"
      ],
      "strategy": "mixed-reuse-rewrite",
      "status": "planned"
    },
    "editor": {
      "description": "Monaco text editor core",
      "vscode_files": 620,
      "sublayers": {
        "common": { "files": 200, "strategy": "reuse", "status": "planned" },
        "browser": { "files": 100, "strategy": "reuse", "status": "planned" },
        "contrib": { "files": 300, "strategy": "reuse", "status": "planned", "contribution_count": 57 },
        "standalone": { "files": 20, "strategy": "reuse", "status": "planned" }
      }
    },
    "workbench": {
      "description": "IDE shell - 92 features, 90 services, 8 visual Parts",
      "vscode_files": 3674,
      "sublayers": {
        "browser": { "files": 150, "strategy": "reuse-with-mods", "status": "planned" },
        "common": { "files": 29, "strategy": "reuse", "status": "planned" },
        "contrib": { "files": 2482, "strategy": "incremental-port", "status": "planned", "feature_count": 92 },
        "services": { "files": 643, "strategy": "incremental-port", "status": "planned", "service_count": 90 },
        "api": { "files": 299, "strategy": "port", "status": "planned" },
        "electron-browser": { "files": 12, "strategy": "rewrite-tauri", "status": "planned" }
      }
    },
    "code": {
