      "sublayers": {
        "electron-main": { "files": 20, "strategy": "rewrite-rust", "status": "planned" },
        "node": { "files": 10, "strategy": "rewrite-rust", "status": "planned" }
      }
    }
  },
  "rust_backend": {
    "commands": [
      "fs::read_file", "fs::write_file", "fs::read_dir", "fs::stat", "fs::mkdir",
      "fs::remove", "fs::rename", "fs::watch", "fs::search_files", "fs::search_text",
      "window::create", "window::close", "window::focus", "window::set_title",
      "dialog::open_file", "dialog::save_file", "dialog::message_box",
      "terminal::spawn", "terminal::write", "terminal::resize", "terminal::kill",
      "process::spawn", "process::kill", "process::list",
      "os::info", "os::env", "os::homedir",
      "clipboard::read", "clipboard::write",
      "crypto::hash", "crypto::encrypt", "crypto::decrypt",
      "shell::open_external", "shell::show_in_folder",
      "storage::get", "storage::set", "storage::delete",
      "git::status", "git::diff", "git::log"
    ],
    "native_replacements": {
      "node-pty": "portable-pty",
      "@parcel/watcher": "notify",
      "native-keymap": "keyboard-layout crate",
      "@vscode/spdlog": "tracing + tracing-subscriber",
      "electron safeStorage": "keyring crate",
      "SQLite storage": "rusqlite"
    }
  },
  "electron_api_replacements": {
    "BrowserWindow": "tauri::WebviewWindow",
    "ipcMain/ipcRenderer": "tauri::command + tauri::event",
    "Menu/MenuItem": "tauri::menu",
    "dialog": "@tauri-apps/plugin-dialog",
    "clipboard": "@tauri-apps/plugin-clipboard-manager",
    "shell": "@tauri-apps/plugin-opener",
    "Notification": "@tauri-apps/plugin-notification",
    "autoUpdater": "@tauri-apps/plugin-updater",
    "protocol": "tauri custom protocol handler",
    "screen": "tauri monitor API",
    "powerMonitor": "sysinfo crate",
    "contentTracing": "tracing crate",
    "contextBridge": "not needed (direct @tauri-apps/api)",
    "utilityProcess": "rust async tasks + sidecar",
    "webContents": "tauri webview API"
  }
}
